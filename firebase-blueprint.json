{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile and statistics",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "points": { "type": "number" },
        "gamesPlayed": { "type": "number" },
        "gamesWon": { "type": "number" }
      },
      "required": ["uid", "displayName"]
    },
    "Game": {
      "title": "Game Session",
      "description": "A multiplayer game session between two players",
      "type": "object",
      "properties": {
        "player1": { "type": "string" },
        "player2": { "type": "string" },
        "player1Name": { "type": "string" },
        "player2Name": { "type": "string" },
        "player1Secret": { "type": "number" },
        "player2Secret": { "type": "number" },
        "status": { "type": "string", "enum": ["waiting", "selecting", "playing", "finished"] },
        "turn": { "type": "string" },
        "history": { "type": "array" },
        "winner": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "range": { "type": "number" }
      },
      "required": ["player1", "status"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/games/{gameId}": {
      "schema": "Game",
      "description": "Active and past game sessions"
    }
  }
}
